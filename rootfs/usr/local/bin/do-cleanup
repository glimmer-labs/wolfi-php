#!/bin/sh

WOLFI_BASE_FLAG=false

for arg in "$@"; do
    case "$arg" in
        "--wolfi-base")
            WOLFI_BASE_FLAG=true
            ;;
        *)
            echo "Unknown option: $arg" >&2
            exit 1
            ;;
    esac
done

remove-composer

# Remove all scripts in /usr/local/bin (except this script for now)
for script in install-composer add-php-extensions add-composer-extensions install-php install-frankenphp remove-composer add-shyim-repo add-glimmer-labs-repo list-installed-modules echo-color; do
    if [ -f "/usr/local/bin/$script" ]; then
        echo "Removing $script"
        rm "/usr/local/bin/$script"
    fi
done

# Remove this script itself
echo "Removing cleanup script"
rm -- "$0"

if [ "$WOLFI_BASE_FLAG" = true ]; then
    echo "Removing wolfi-base apk-tools and busybox"
    
    busyboxFiles="$(apk info --no-cache -L busybox | tail -n +2)"
    symlinks=""

    for d in /bin /usr/bin /sbin /usr/sbin; do
        for f in "$d"/*; do
            if [ -L "$f" ]; then
            target=$(readlink "$f")
            case "$target" in
                *busybox*) symlinks="$symlinks $f" ;;
            esac
            fi
        done
    done

    apk del --no-cache apk-tools wolfi-keys wolfi-base
    rm -rf $busyboxFiles $symlinks /etc/apk /lib/apk /var/lib/apk /usr/share/apk /etc/busybox*
fi

echo "Cleanup complete"
